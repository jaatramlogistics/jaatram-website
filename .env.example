# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

# Contact form email (where quote requests get sent)
CONTACT_EMAIL=jaaatramlogistics@gmail.com

# Resend API key for sending emails (get free key at resend.com)
RESEND_API_KEY=re_your_key_here

# Google Maps Embed API key (optional - maps still show without it)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_key_here

# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://jaaatramlogistics.com
